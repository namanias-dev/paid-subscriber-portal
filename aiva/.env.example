# ============================================================================
# AIVA (namanias-aiva) — environment. Separate Vercel project, SAME Supabase DB.
# Copy to aiva/.env.local for local dev. Never commit real secrets.
# ============================================================================

# --- Shared database (same Supabase project as the portal) ---
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- AIVA session ---
# Dedicated secret recommended. Falls back to ADMIN_JWT_SECRET if unset.
AIVA_JWT_SECRET=
AIVA_SESSION_DAYS=7

# --- Feature flags (first release = private, super-admin-only, READ-ONLY) ---
AIVA_ENABLED=true
AIVA_READ_ONLY=true
AIVA_3D_BRAIN_ENABLED=true
AIVA_WEBSITE_RECOMMENDATIONS_ENABLED=false
AIVA_CAMPAIGNS_ENABLED=false
AIVA_INSTALLMENT_REMINDERS_ENABLED=false
AIVA_LOCAL_WORKER_ENABLED=false
AIVA_OPENCLAW_ENABLED=false
AIVA_LEARNING_ENABLED=false
AIVA_AUTO_GREEN_ACTIONS_ENABLED=false
AIVA_EMIT_EVENTS=false
AIVA_DATA_RETENTION_DAYS=180

# --- Read-only posture note ---
# SMS_ENABLED is controlled by the PORTAL project. AIVA never sends SMS in v1.
