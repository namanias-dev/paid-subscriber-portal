# ─────────────────────────────────────────────────────────────────────────────
# Naman IAS — AI Counselor local worker (OPTIONAL). Copy to `.env` and fill in.
# This file configures a worker that runs on YOUR machine/server, NOT on Vercel.
# NONE of these belong in Vercel Production.
# ─────────────────────────────────────────────────────────────────────────────

# The portal to talk to. Use the PREVIEW/production HTTPS URL of the site.
# The worker only ever calls the HMAC-gated /api/ai-agent/worker/* endpoints.
PORTAL_BASE_URL=https://naman-ias-git-feature-ai-agent-phase5-naman-ias-academy.vercel.app

# Shared HMAC secret. Must EXACTLY match AI_AGENT_HMAC_SECRET set on the portal
# (Preview env only). Generate: `openssl rand -hex 32`. Keep it secret.
AI_AGENT_HMAC_SECRET=

# Local Ollama server (never exposed to the internet).
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_MS=8000

# Scheduler. Comma-separated task list (or "all"). Interval for 24/7 mode.
WORKER_TASKS=all
WORKER_INTERVAL_MS=900000
