# ============================================================
# Naman Sharma IAS Academy — Subscriber Portal
# ALL VARIABLES ARE OPTIONAL. With none set, the app runs in
# DEMO MODE (mock data, demo logins, no real payments).
# Add them in Vercel later to automatically go LIVE.
# ============================================================

# --- Supabase (Postgres). Presence of URL flips app to LIVE mode. ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth secrets (set strong random values in production!) ---
JWT_SECRET=
ADMIN_JWT_SECRET=

# --- Razorpay (payments). Absent => demo payment toast. ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Static Razorpay Payment Links (one per plan) ---
NEXT_PUBLIC_RAZORPAY_LINK_1M=
NEXT_PUBLIC_RAZORPAY_LINK_3M=
NEXT_PUBLIC_RAZORPAY_LINK_6M=
NEXT_PUBLIC_RAZORPAY_LINK_12M=
NEXT_PUBLIC_RAZORPAY_LINK_LIFETIME=

# --- ICICI Eazypay (payments). Absent AES key => demo/simulated payments. ---
# AES key is BACKEND-ONLY: never expose via NEXT_PUBLIC_, never commit a real key.
ICICI_EAZYPAY_AES_KEY=
ICICI_EAZYPAY_MERCHANT_ID=343526
ICICI_EAZYPAY_RETURN_URL=https://namanias.com/api/v1/bank/payment
# Optional: JSON map of item slug/id -> SubMerchantID (fallback is "11")
ICICI_EAZYPAY_SUBMERCHANT_MAP=
# Minutes a fresh PENDING waits before we move it to VERIFYING (default 120 = 2h).
# Keep this generous so slow UPI/netbanking callbacks have time to land; during
# the window the student sees "verifying", never "failed". (Legacy
# WEBINAR_PENDING_TIMEOUT_MINUTES is no longer used for the window.)
WEBINAR_PENDING_WINDOW_MINUTES=120
WEBINAR_PENDING_TIMEOUT_MINUTES=10
# --- ICICI Eazypay Verify URL (transaction STATUS API) egress ---
# ICICI firewalls EazyPGVerify by source IP. On Vercel (dynamic egress) route the
# call through a fixed IP that ICICI has whitelisted for merchant 343526.
#   * HTTP forward proxy (QuotaGuard Static / Fixie):  http://user:pass@host:port
#   * Relay endpoint (set EAZYPAY_VERIFY_PROXY_MODE=relay): your static-IP service
#     that fetches ?target=<encoded url> (or substitutes a {target} placeholder).
# Leave blank to call ICICI directly (only works if THIS server's IP is whitelisted).
EAZYPAY_VERIFY_PROXY_URL=
EAZYPAY_VERIFY_PROXY_MODE=

# --- Public portal URL (used in WhatsApp messages) ---
NEXT_PUBLIC_PORTAL_URL=https://portal.example.com

# --- Resend email (optional). Absent => emails skipped silently. ---
RESEND_API_KEY=

# --- Keep-alive cron secret (also guards /api/cron/analytics-rollup + /api/cron/sms-dispatch) ---
CRON_SECRET=

# ============================================================
# In-portal SMS (JustGoSMS) — BACKEND ONLY. Never expose via NEXT_PUBLIC_,
# never log. With keys absent, SMS Mission Control still runs but sends are
# marked "gateway_not_configured" (nothing leaves). Pabbly stays untouched.
# ============================================================
# Master kill switch. Stays OFF unless set to exactly "true" — flip it on only
# AFTER you've pasted a DLT id and run one manual test from Mission Control.
SMS_ENABLED=false
# JustGoSMS is HTTP-only: the host kills the TLS handshake on :443, so https fails
# from every egress (incl. Vercel). Keep these on http:// unless the gateway fixes TLS.
SMS_API_BASE_URL=http://justgosms.com/http-api.php
# Delivery-report PULL endpoint (http-dlr.php?username&password&msg_id=).
SMS_DLR_BASE_URL=http://justgosms.com/http-dlr.php
SMS_API_AUTH_KEY=
SMS_API_USERNAME=
SMS_API_PASSWORD=
# Provisioned domestic route for this account (verified via http-credit.php). Route 1/18 are NOT valid here.
SMS_API_DEFAULT_ROUTE=12
SMS_API_DEFAULT_SENDER_ID=NAMIAS
# Wire format for the gateway `number` param. Confirm against a JustGoSMS sample:
#   10digit  -> 9876543210   |   91prefix -> 919876543210
SMS_NUMBER_FORMAT=10digit
# Anti-spam caps (0 = unlimited). Per-mobile cap applies across ALL templates.
SMS_DAILY_CAP=
SMS_PER_MOBILE_DAILY_CAP=
# Short links used inside template bodies (keep < 155 chars). Defaults derive
# from NEXT_PUBLIC_SITE_URL when unset.
SMS_LOGIN_URL=
SMS_WEBINARS_URL=
SMS_COURSE_URL=
# Delivery-receipt (DLR) callback secret. JustGoSMS pushes handset delivery
# status to /api/v1/sms/dlr?token=<this>. Falls back to CRON_SECRET when unset.
SMS_DLR_TOKEN=

# ============================================================
# SEO / Search Console
# ============================================================
# Canonical site origin (no trailing slash). The site 308-redirects the apex
# namanias.com -> www.namanias.com, so set this to the www host in production so
# robots.txt + sitemap.xml emit canonical www URLs. Defaults to https://namanias.com.
NEXT_PUBLIC_SITE_URL=https://www.namanias.com
# Google Search Console HTML-tag verification token. Get it from GSC when adding a
# URL-prefix property: Add property > URL prefix > "HTML tag" method > copy the
# value of the `content="..."` attribute (NOT the whole tag). When set, the root
# layout renders <meta name="google-site-verification" content="..."> server-side.
# Leave blank => no tag is emitted (clean no-op). Recommended primary method is
# instead a DNS TXT record on a GSC "Domain" property (covers apex + www + subdomains).
NEXT_PUBLIC_GSC_VERIFICATION=

# ============================================================
# In-house analytics + attribution (FIRST-PARTY) runs with NO keys.
# The vars below are ONLY for the OPTIONAL 3rd-party layer and stay
# completely INERT until set AND the user grants consent.
# ============================================================
# --- PostHog (behaviour analytics / session replay / funnels) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# --- Google Analytics 4 (GA4). Independent of Meta + in-house analytics. ---
# Measurement ID (Admin > Data Streams > your web stream), format G-XXXXXXXXXX.
# Absent/empty => GA4 fully INERT (no gtag.js injected, zero errors). Loads only
# on PUBLIC marketing pages AND only after MARKETING consent (nsa_consent).
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# --- Meta Pixel + server-side Conversions API (attribution & revenue) ---
# Dataset/Pixel ID (Events Manager > Data Sources > your dataset > Settings).
# Used by BOTH the browser pixel (public) and server CAPI (falls back to this).
NEXT_PUBLIC_META_PIXEL_ID=
# Optional: separate server-only dataset id (usually leave blank; = pixel id).
META_PIXEL_ID=
# CAPI access token (Events Manager > Settings > Conversions API > Generate).
META_CAPI_ACCESS_TOKEN=
# Optional: Meta Test Events code while validating CAPI in Events Manager.
META_TEST_EVENT_CODE=
# G1 HARD GATE — advanced matching (sends HASHED phone/email to Meta). Leave OFF
# ("0"/blank) until data-policy sign-off. fbc/fbp/event_id matching works without it.
META_ADVANCED_MATCHING=0
# Optional: override the Meta Graph API version (defaults to a current version).
META_GRAPH_VERSION=
# Optional: Ad Account ID (act_XXXXXXXX) — enables spend / CPA / ROAS in the
# admin attribution dashboard. Attribution (leads/revenue) works without it.
META_AD_ACCOUNT_ID=

# ============================================================
# Cloudflare R2 — HOSTED LECTURE RECORDINGS (BACKEND ONLY).
# Absent => hosted-video upload/playback is disabled (link recordings still work).
# Never expose via NEXT_PUBLIC_; bucket must be PRIVATE; video is served via
# short-lived signed URLs. Configure bucket CORS to allow multipart PUT and
# expose the ETag header (see handoff). Recommended: an R2 lifecycle rule to
# abort incomplete multipart uploads after ~1 day.
# ============================================================
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_ENDPOINT=
# Optional: public CDN base URL, ONLY for public lectures explicitly opted into CDN caching.
CLOUDFLARE_R2_PUBLIC_BASE_URL=
# Signed playback URL lifetime (seconds). Default 1800 (30 min).
LECTURE_SIGNED_URL_TTL_SECONDS=1800

# ============================================================
# Demo credentials (DEMO MODE only) — NOT real secrets.
# These let you log in while exploring with zero setup.
# Override them if you want different demo logins.
# In LIVE mode, student/admin auth comes from Supabase instead.
# ============================================================
DEMO_STUDENT_PHONE=9999999999
DEMO_STUDENT_ACCESS_CODE=NS-0000-DEMO
DEMO_ADMIN_USERNAME=demoadmin
DEMO_ADMIN_PASSWORD=DemoAdmin2025

# --- Public contact details shown on the website ---
SUPPORT_PHONE=
SUPPORT_EMAIL=

# ============================================================
# Quiz platform — Google Sheets question import (OPTIONAL)
# Default import path needs NO credentials: share the sheet as
# "Anyone with the link can view" (or Publish to web) and paste its URL.
# The keys below are only needed for PRIVATE sheets via a service account
# (currently a documented TODO; not required for the public-sheet path).
# ============================================================
GOOGLE_SHEETS_PROJECT_ID=
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
