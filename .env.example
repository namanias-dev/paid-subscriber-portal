# ============================================================
# Naman Sharma IAS Academy — Subscriber Portal
# ALL VARIABLES ARE OPTIONAL. With none set, the app runs in
# DEMO MODE (mock data, demo logins, no real payments).
# Add them in Vercel later to automatically go LIVE.
# ============================================================

# --- Supabase (Postgres). Presence of URL flips app to LIVE mode. ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth secrets (set strong random values in production!) ---
JWT_SECRET=
ADMIN_JWT_SECRET=

# --- Razorpay (payments). Absent => demo payment toast. ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Static Razorpay Payment Links (one per plan) ---
NEXT_PUBLIC_RAZORPAY_LINK_1M=
NEXT_PUBLIC_RAZORPAY_LINK_3M=
NEXT_PUBLIC_RAZORPAY_LINK_6M=
NEXT_PUBLIC_RAZORPAY_LINK_12M=
NEXT_PUBLIC_RAZORPAY_LINK_LIFETIME=

# --- ICICI Eazypay (payments). Absent AES key => demo/simulated payments. ---
# AES key is BACKEND-ONLY: never expose via NEXT_PUBLIC_, never commit a real key.
ICICI_EAZYPAY_AES_KEY=
ICICI_EAZYPAY_MERCHANT_ID=343526
ICICI_EAZYPAY_RETURN_URL=https://namanias.com/api/v1/bank/payment
# Optional: JSON map of item slug/id -> SubMerchantID (fallback is "11")
ICICI_EAZYPAY_SUBMERCHANT_MAP=

# --- Public portal URL (used in WhatsApp messages) ---
NEXT_PUBLIC_PORTAL_URL=https://portal.example.com

# --- Resend email (optional). Absent => emails skipped silently. ---
RESEND_API_KEY=

# --- Keep-alive cron secret ---
CRON_SECRET=

# ============================================================
# Cloudflare R2 — HOSTED LECTURE RECORDINGS (BACKEND ONLY).
# Absent => hosted-video upload/playback is disabled (link recordings still work).
# Never expose via NEXT_PUBLIC_; bucket must be PRIVATE; video is served via
# short-lived signed URLs. Configure bucket CORS to allow multipart PUT and
# expose the ETag header (see handoff). Recommended: an R2 lifecycle rule to
# abort incomplete multipart uploads after ~1 day.
# ============================================================
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_ENDPOINT=
# Optional: public CDN base URL, ONLY for public lectures explicitly opted into CDN caching.
CLOUDFLARE_R2_PUBLIC_BASE_URL=
# Signed playback URL lifetime (seconds). Default 1800 (30 min).
LECTURE_SIGNED_URL_TTL_SECONDS=1800

# ============================================================
# Demo credentials (DEMO MODE only) — NOT real secrets.
# These let you log in while exploring with zero setup.
# Override them if you want different demo logins.
# In LIVE mode, student/admin auth comes from Supabase instead.
# ============================================================
DEMO_STUDENT_PHONE=9999999999
DEMO_STUDENT_ACCESS_CODE=NS-0000-DEMO
DEMO_ADMIN_USERNAME=demoadmin
DEMO_ADMIN_PASSWORD=DemoAdmin2025

# --- Public contact details shown on the website ---
SUPPORT_PHONE=
SUPPORT_EMAIL=

# ============================================================
# Quiz platform — Google Sheets question import (OPTIONAL)
# Default import path needs NO credentials: share the sheet as
# "Anyone with the link can view" (or Publish to web) and paste its URL.
# The keys below are only needed for PRIVATE sheets via a service account
# (currently a documented TODO; not required for the public-sheet path).
# ============================================================
GOOGLE_SHEETS_PROJECT_ID=
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
